{
  "name": "github-flex",
  "version": "0.0.10",
  "description": "Browser extension to expand GitHub's interface",
  "private": true,
  "license": "MIT",
  "author": "Lam Ngoc Khuong <hi@khuong.dev>",
  "type": "module",
  "scripts": {
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --write",
    "format": "biome format src/ --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "pnpm lint && pnpm test",
    "lint:firefox": "web-ext lint --source-dir dist/firefox",
    "build": "node scripts/build.js",
    "build:chrome": "node scripts/build.js --chrome",
    "build:firefox": "node scripts/build.js --firefox",
    "dev": "node scripts/build.js --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@vitest/coverage-v8": "4.1.4",
    "esbuild": "0.28.0",
    "vitest": "4.1.4",
    "web-ext": "10.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "diff": "9.0.0",
    "webextension-polyfill": "0.12.0"
  }
}
