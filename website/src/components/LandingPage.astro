---
import { useTranslations, type Locale } from '../i18n';
import { CHROME_STORE_URL, FIREFOX_ADDONS_URL } from '../constants';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const screenshots = [
  { src: '/screenshots/wide-layout.svg', alt: 'Wide Layout' },
  { src: '/screenshots/lightbox.svg', alt: 'Image Lightbox' },
  { src: '/screenshots/gif-picker.svg', alt: 'GIF Picker' },
  { src: '/screenshots/sidebar-toggle.svg', alt: 'Sidebar Toggle' },
];
---

<!-- Hero Section -->
<section class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 pt-16">
  <div class="max-w-4xl mx-auto text-center">
    <img src="/logo.svg" alt="GitHub Flex" class="w-24 h-24 sm:w-32 sm:h-32 mx-auto mb-6" />
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-primary dark:text-primary-light mb-6">
      {t.hero.tagline}
    </h1>
    <p class="text-lg sm:text-xl text-text-muted dark:text-text-muted-dark mb-8 max-w-2xl mx-auto">
      {t.hero.description}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6">
      <a
        href={CHROME_STORE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-primary hover:bg-primary-hover text-white text-lg rounded-lg font-semibold transition-colors shadow-lg"
      >
        <img src="/chrome-logo.svg" alt="Chrome" class="w-6 h-6" />
        {t.hero.ctaChrome}
      </a>
      <a
        href={FIREFOX_ADDONS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF7139] hover:bg-[#E65A2C] text-white text-lg rounded-lg font-semibold transition-colors shadow-lg"
      >
        <img src="/firefox-logo.svg" alt="Firefox" class="w-6 h-6" />
        {t.hero.ctaFirefox}
      </a>
    </div>
    <!-- Browser Icons -->
    <div class="flex items-center justify-center gap-3 sm:gap-6 flex-wrap">
      <!-- Chrome -->
      <div class="browser-icon flex-shrink-0" title="Chrome">
        <img src="/chrome-logo.svg" alt="Chrome" class="w-8 h-8 sm:w-10 sm:h-10" />
      </div>
      <!-- Edge -->
      <div class="browser-icon flex-shrink-0" title="Microsoft Edge">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="0 0 256 256">
          <defs><linearGradient id="e-a" x1="63%" x2="13%" y1="68%" y2="23%"><stop offset="0" stop-color="#0c59a4"/><stop offset="1" stop-color="#114a8b"/></linearGradient><linearGradient id="e-b" x1="60%" x2="19%" y1="40%" y2="85%"><stop offset="0" stop-color="#1b9de2"/><stop offset="1" stop-color="#0078d4"/></linearGradient></defs>
          <path fill="url(#e-a)" d="M231 190c-4 2-8 3-12 4-13 4-27 6-41 6-44 0-82-30-82-69 0-11 6-20 15-25-40 2-50 43-50 67 0 68 63 75 76 75 7 0 18-2 25-4l1 0c25-8 46-25 61-49 2-3-1-7-5-5z"/>
          <path fill="url(#e-b)" d="M107 233c-8-6-14-13-19-22-9-17-14-36-14-56 0-25 7-48 21-67 6-9 13-16 22-22 31-24 74-24 100-4a67 67 0 0 0-59-56c-38-4-76 11-102 40-22 25-35 57-35 91 0 21 5 39 11 52 16 34 46 61 84 69 10 2 19 3 29 3-14-3-27-10-38-20v-8z"/>
        </svg>
      </div>
      <!-- Brave -->
      <div class="browser-icon flex-shrink-0" title="Brave">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="0 0 256 256">
          <linearGradient id="b-a" y1="51%" y2="51%"><stop offset=".4" stop-color="#f50"/><stop offset=".6" stop-color="#ff2000"/></linearGradient>
          <path fill="url(#b-a)" d="M222 67l6-14-16-16c-9-9-27-4-27-4l-21-23H92L71 33s-18-5-27 4L28 52l6 14-7 20 23 88c5 19 8 26 22 36l42 29c4 2 9 7 14 7s10-4 14-7l42-29c14-10 17-17 22-36l23-88z"/>
          <path fill="#fff" d="M180 49s26 32 26 39c0 7-3 9-7 12l-20 21c-2 2-6 5-4 11 3 5 6 12 2 19-4 7-10 12-14 11a75 75 0 0 1-18-8c-3-2-15-12-15-15s12-10 14-11c2-2 12-8 12-10s0-3-3-8-8-13-7-18c1-5 9-7 15-10l19-7c2-1 1-1-3-2s-17-2-23 0-15 4-16 5c-1 1-1 1-1 6l6 29c0 4 1 6-3 7s-11 3-13 3-9-2-13-3-3-3-3-7c0-4 5-25 5-29 1-4 0-4-1-6-1-1-10-4-16-5s-18 0-22 0-5 1-4 2l20 7c6 2 14 5 15 10 1 5-4 12-7 18s-3 6-3 8 10 8 12 10c3 1 14 8 14 11s-12 13-15 15a75 75 0 0 1-17 8c-4 1-11-4-15-11-3-7 0-14 2-19 2-6-2-9-3-11L74 100c-3-3-7-5-7-12s27-39 27-39l25 4c3 0 10-2 16-5 6-2 10-2 10-2s4 0 10 2c6 3 13 5 16 5zm-20 122c2 1 1 3-1 4l-23 18c-2 2-5 5-7 5s-5-3-7-5l-23-18c-2-1-2-3-1-4l14-7a79 79 0 0 1 17-7c1 0 10 3 17 7z"/>
        </svg>
      </div>
      <!-- Opera -->
      <div class="browser-icon flex-shrink-0" title="Opera">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="0 0 256 256">
          <linearGradient id="o-a" x1="43%" x2="43%" y1="6%" y2="96%"><stop offset=".6" stop-color="#ff1b2d"/><stop offset="1" stop-color="#a70014"/></linearGradient>
          <path fill="url(#o-a)" d="M128 10a118 118 0 1 0 79 206 85 85 0 0 1-47 14c-28 0-53-14-70-36-13-15-21-38-22-64v-4c1-26 9-49 22-64 17-22 42-36 70-36 18 0 34 5 47 14A117 117 0 0 0 128 10z"/>
          <linearGradient id="o-b" x1="67%" x2="67%" y1="14%" y2="91%"><stop offset="0" stop-color="#9c0000"/><stop offset=".7" stop-color="#ff4b4b"/></linearGradient>
          <path fill="url(#o-b)" d="M89 62c11-13 25-20 40-20 34 0 62 39 62 87s-28 87-62 87c-15 0-29-8-40-21 17 22 42 36 70 36a85 85 0 0 0 47-14 118 118 0 0 0 0-176 85 85 0 0 0-47-14c-28 0-53 14-70 36"/>
        </svg>
      </div>
      <!-- Vivaldi -->
      <div class="browser-icon flex-shrink-0" title="Vivaldi">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="0 0 256 256">
          <path fill="#ef3939" d="M128 246c52 0 81 0 100-19s19-48 19-100-0-81-19-100S180 8 128 8s-81 0-100 19S9 75 9 128s0 81 19 100 48 19 100 19z"/>
          <path fill="#fff" d="M190 65a89 89 0 0 0-126 0 89 89 0 0 0 0 126 89 89 0 0 0 126 0 89 89 0 0 0 0-126zm-5 41l-44 76c-3 5-7 8-12 8-6 0-11-2-14-7l-45-77c-6-10 1-22 12-22 6 0 11 2 14 8l9 21 9 15c4 8 11 12 19 12 12 0 24-8 25-21 0 0 0-2 0-2 0-4-1-8-3-11-5-9 0-19 10-22 8-2 16 4 17 12 1 4 0 7-2 10z"/>
        </svg>
      </div>
      <!-- Arc -->
      <div class="browser-icon flex-shrink-0" title="Arc">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="0 0 82 82">
          <path d="m28.8 51.97 6.35-13.36c-4.85-1.03-9.73-4.03-12.49-7.68l-6.64 13.96c3.69 3.13 8.12 5.59 12.78 7.08" fill="#1a007f"/>
          <path d="M55.3 30.53c-3.19 3.91-7.62 6.81-12.36 7.94l6.33 13.32c4.62-1.56 8.94-4.08 12.67-7.31L55.3 30.53z" fill="#4e000a"/>
          <path d="m16.02 44.89-3.32 6.98c-1.69 3.55-.42 7.92 3.06 9.77 3.69 1.96 8.23.43 10.01-3.3l3.03-6.37a37.885 37.885 0 0 1-12.78-7.08" fill="#1a007f"/>
          <path d="M68.48 15.29a7.29 7.29 0 0 0-8.58 5.72c-.7 3.5-2.34 6.76-4.6 9.53l6.63 13.96c6.12-5.31 10.64-12.54 12.26-20.63.79-3.96-1.77-7.8-5.71-8.58" fill="#ff9396"/>
          <path d="M42.94 38.47c-1.42.34-2.87.52-4.32.52-1.13 0-2.3-.13-3.47-.38-4.85-1.03-9.73-4.03-12.49-7.68-.69-.91-1.25-1.86-1.64-2.83-1.51-3.73-5.76-5.53-9.49-4.03C7.8 25.58 6 29.83 7.5 33.56c1.71 4.24 4.73 8.13 8.52 11.33a37.84 37.84 0 0 0 12.77 7.08c3.21 1.03 6.54 1.6 9.82 1.6 3.64 0 7.23-.63 10.65-1.78l-6.32-13.32z" fill="#002dc8"/>
          <path d="m65.43 51.84-3.5-7.36-6.63-13.95-.01.01s0-.01.01-.01l-9.64-20.28a7.292 7.292 0 0 0-6.58-4.16c-2.81 0-5.37 1.62-6.58 4.16l-9.83 20.68c2.76 3.65 7.64 6.65 12.49 7.68l3.18-6.68c.3-.63 1.2-.63 1.5 0l3.11 6.54h.02-.02l6.33 13.32 3.11 6.54a7.28 7.28 0 0 0 6.59 4.16c.65 0 1.3-.09 1.94-.27 4.39-1.21 6.47-6.26 4.51-10.38" fill="#ff536a"/>
        </svg>
      </div>
      <!-- Firefox -->
      <div class="browser-icon flex-shrink-0" title="Firefox">
        <img src="/firefox-logo.svg" alt="Firefox" class="w-8 h-8 sm:w-10 sm:h-10" />
      </div>
    </div>
    <p class="mt-3 text-xs text-text-muted dark:text-text-muted-dark opacity-75">
      {t.hero.subtext}
    </p>
  </div>
</section>

<!-- Features Section -->
<section id="features" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-4">
      {t.features.title}
    </h2>
    <p class="text-center text-text-muted dark:text-text-muted-dark mb-12 max-w-2xl mx-auto">
      {t.features.subtitle}
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {t.features.items.map(feature => (
        <div class="p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4">{feature.icon}</div>
          <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
            {feature.title}
          </h3>
          <p class="text-text-muted dark:text-text-muted-dark">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Screenshots Section -->
<section id="screenshots" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8 bg-card-light dark:bg-card-dark">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-4">
      {t.screenshots.title}
    </h2>
    <p class="text-center text-text-muted dark:text-text-muted-dark mb-12 max-w-2xl mx-auto">
      {t.screenshots.subtitle}
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      {screenshots.map(screenshot => (
        <div class="rounded-xl overflow-hidden border border-border-light dark:border-border-dark shadow-lg">
          <img
            src={screenshot.src}
            alt={screenshot.alt}
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<!-- How It Works Section -->
<section id="how-it-works" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-4">
      {t.howItWorks.title}
    </h2>
    <p class="text-center text-text-muted dark:text-text-muted-dark mb-12 max-w-2xl mx-auto">
      {t.howItWorks.subtitle}
    </p>

    <div class="space-y-8">
      {t.howItWorks.steps.map((step, index) => (
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center text-xl font-bold">
            {index + 1}
          </div>
          <div>
            <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
              {step.title}
            </h3>
            <p class="text-text-muted dark:text-text-muted-dark">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href="#"
        class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-primary hover:bg-primary-hover text-white rounded-lg font-semibold transition-colors scroll-to-top"
      >
        {t.howItWorks.cta}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section id="faq" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8 bg-card-light dark:bg-card-dark">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-4">
      {t.faq.title}
    </h2>
    <p class="text-center text-text-muted dark:text-text-muted-dark mb-12">
      {t.faq.subtitle}
    </p>

    <div class="space-y-4">
      {t.faq.items.map(item => (
        <details class="group p-6 rounded-xl border border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark">
          <summary class="cursor-pointer font-semibold text-lg text-primary dark:text-primary-light list-none flex items-center justify-between">
            <span>{item.question}</span>
            <span class="transition-transform group-open:rotate-180">▼</span>
          </summary>
          <p class="mt-4 text-text-muted dark:text-text-muted-dark">
            {item.answer}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .browser-icon {
    opacity: 0.7;
    transition: all 0.2s ease;
    cursor: default;
  }
  .browser-icon:hover {
    opacity: 1;
    transform: scale(1.15);
  }
</style>

<script>
  document.querySelector('.scroll-to-top')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
